CLIENT=${CLIENT:-reth}
HOST_DATA_DIR=./${CLIENT}-data
USE_BASE_CONSENSUS=true

# OPTIONAL NETWORKING SETTINGS
# Advertises your public IP to P2P peers for better discovery.
# HOST_IP=<your-public-ip>

# OPTIONAL STORAGE SETTINGS
# Override the host directory where chain data is stored.
# HOST_DATA_DIR=/path/to/chain-data
